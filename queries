-- 1. OVER() — the absolute basics 
-- Total revenue per order line, plus the GRAND TOTAL repeated on every row
SELECT 
    id,
    buyer_name,
    product_name,
    purchase_price,
    SUM(purchase_price) OVER () AS total_revenue
FROM orders

--2. OVER (PARTITION BY ...) — split the window into groups
-- NUM of ORDERS per buyer
SELECT 
    id,
    buyer_name,
    product_name,
    purchase_price,
    COUNT(*) OVER (PARTITION BY buyer_name) AS orders_by_buyer
FROM orders
-- from produits : 
SELECT 
    id,
    name,
    categorie,
    price,
    AVG(price) OVER (PARTITION BY categorie) AS total_per_categorie
FROM produits

--3. ORDER BY inside OVER() — running totals
SELECT 
    id,
    name,
    categorie,
    price,
    SUM(price) OVER (ORDER BY id ) AS running_total
FROM produits

--4. ROW_NUMBER() — unique sequential numbering
SELECT 
    id,
    name,
    categorie,
    price,
    ROW_NUMBER() OVER (ORDER BY price DESC) AS row_num
FROM produits

--5. RANK() et DENSE_RANK() 
SELECT 
    id,
    name,
    categorie,
    price,
    RANK() OVER (ORDER BY price DESC) AS rank_high_price
FROM produits
-- + --
SELECT
    categorie,
    name,
    price,
    RANK() OVER (PARTITION BY categorie ORDER BY price) AS rang_rank
FROM produits
ORDER BY rang_rank

-- Force a clear tie example: rank ALL products by price, ignoring category
SELECT
    name,
    categorie,
    price,
    DENSE_RANK() OVER (ORDER BY price DESC) AS rang_dense_rank
FROM produits
ORDER BY price
--6. LAG() and LEAD() — look at previous/next row
-- For each buyer, compare each order's price to their PREVIOUS order
SELECT 
    name,
    categorie,
    price,
    LAG(price) OVER (ORDER BY id) AS previous_price
FROM produits
-- + -- 
SELECT 
    buyer_name,
    purchase_price,
    LAG(purchase_price) OVER (PARTITION BY buyer_name ORDER BY id) AS previous_purchase
FROM orders
--+--
SELECT 
    id,
    buyer_name,
    purchase_price,
    LEAD(purchase_price) OVER (PARTITION BY buyer_name ORDER BY id) AS next_price
FROM orders

--7. AVG() OVER() — comparing a row to the average
SELECT 
    id,
    name,
    categorie,
    price,
    SUM(price) OVER (PARTITION BY categorie) AS total_price_categorie
FROM produits;
--++--
SELECT 
    id,
    buyer_name,
    product_name,
    purchase_price,
    SUM(purchase_price * quantity) OVER (PARTITION BY buyer_name) AS total_bought
FROM orders
-- Compare each product's price to the AVERAGE price in its category
SELECT 
    id,
    name,
    categorie,
    price,
    AVG(price) OVER (PARTITION BY categorie) AS avg_price_categorie
FROM produits
--vs 
SELECT * FROM (
    SELECT
        categorie,
        name,
        price,
        AVG(price) OVER (PARTITION BY categorie) AS avg_price_category
    FROM produits
)
WHERE price > avg_price_category;